{
  "version": 2,
  "builds": [
    {
      "src": "server.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server.py"
    },
    {
      "source": "/admin",
      "destination": "admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "admin/index.html"
    },
    {
      "source": "/static/(.*)",
      "destination": "/dist/static/$1"
    },
    {
      "source": "/(.*)",
      "destination": "server.py"
    }
  ]
}