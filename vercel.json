{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server.py"
    },
    {
      "source": "/admin",
      "destination": "admin/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "admin/index.html"
    },
    {
      "source": "/((?!api|admin).*)",
      "destination": "/dist/index.html"
    }
  ]
}